<?xml version="1.0" encoding="utf-8"?>
<!-- Network security configuration for KTMOC Harness -->
<network-security-config>
    <!-- Allow cleartext traffic for local debugging and i2pd eepsites -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    
    <!-- Domain-specific configurations -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">.i2p</domain>
        
        <!-- Hugging Face API -->
        <domain includeSubdomains="true">huggingface.co</domain>
        <domain includeSubdomains="true">api-inference.huggingface.co</domain>
    </domain-config>
</network-security-config>
