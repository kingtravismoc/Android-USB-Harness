  "solver": {
    "riskWeights": {
      "hostility": 1.0,
      "aggression": 0.8,
      "malice": 0.9,
      "dominance": 0.7,
      "humiliation": 1.2,
      "exclusion": 0.6
    },
    "benefitWeights": {
      "empathy": 1.5,
      "respect": 1.3,
      "compassion": 1.4,
      "inclusion": 1.0
    },
    "safetyThreshold": 0.7,
    "epsilon": 1e-6
  },
  
  "temporal": {
    "decayLambda": 0.1,
    "escalationWindow": 10
  },
  
  "4D_analog": {
    "kappa": 0.5,
    "theta": 0.8,
    "temporalJitter": 0.02
  },
  
  "outputs": ["scalars", "vectors", "matrices", "tensors", "graphs", "relations", "prompts"],
  
  "generators": [
    { "name": "T_squared", "expression": "T*T" },
    { "name": "T_inverse", "expression": "1/T" },
    { "name": "T_log", "expression": "log(T)" },
    { "name": "T_exp", "expression": "exp(T)" }
  ]
